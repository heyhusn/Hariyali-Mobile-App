    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/activity_video_search"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_rounded_bg">

        <LinearLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="#F5FFF3">

            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/logo" />

            <TextView
                android:id="@+id/logoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_gravity="center_vertical"
                android:text="Hariyali"
                android:textColor="#25570B"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_regular"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/search_input"
            android:layout_below="@id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter plant name..."
            android:padding="12dp"
            android:background="@android:color/white"
            android:imeOptions="actionSearch"
            android:inputType="text" />

        <WebView
            android:id="@+id/youtube_webview"
            android:layout_below="@id/search_input"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="70dp"
            android:layout_marginLeft="30dp"
            android:backgroundTint="@android:color/holo_green_dark"
            android:src="@drawable/back_icon_for_webview"
            app:fabSize="normal"
            tools:ignore="SpeakableTextPresentCheck" />

    </RelativeLayout>
